# Use "openai" if you only have an OpenAI key; "anthropic" for Claude.
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
X_BEARER_TOKEN=
# Comma-separated CORS origins, or * (default)
ALLOWED_ORIGINS=*
MAX_CRITIC_RETRIES=3
THREAD_MIN=6
THREAD_MAX=9
